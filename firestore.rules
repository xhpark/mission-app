rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /content_sets/{contentSetId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /{document=**} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    match /user_profiles/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /user_runtime/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /user_report_state/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /study_sessions/{userId}/{document=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /test_results/{userId}/{document=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /reports/{userId}/{document=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /resume_states/{userId}/{document=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /daily_links/{dateKey} {
      allow read: if isSignedIn();
      allow write: if false;

      match /clickEvents/{eventId} {
        allow read: if false;
        allow write: if false;
      }
    }

    match /learner_roster/{rosterId} {
      allow read: if false;
      allow write: if false;
    }
  }
}
