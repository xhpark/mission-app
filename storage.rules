rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /speaking_attempts/{userId}/{allPaths=**} {
      allow write: if isOwner(userId) && request.resource.size < 15 * 1024 * 1024;
      allow read: if false;
    }

    match /audio/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
