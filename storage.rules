rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /speaking_attempts/{userId}/{allPaths=**} {
      allow write: if isOwner(userId) && request.resource.size < 15 * 1024 * 1024;
      allow read: if false;
    }

    match /audio/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // On-device speech recognition model bundle (Wi-Fi-gated download from
    // the app). Uploaded by operators via scripts/upload_asr_model.py, never
    // written by clients.
    match /asr_models/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // App install package for distributing to learners before they have an
    // account (no auth yet at install time). Uploaded by operators via
    // scripts/upload_app_release.py, never written by clients.
    match /app_releases/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
