# Firebase Functions environment configuration.
# Copy to functions/.env and fill with real values. functions/.env is gitignored.
# firebase-functions automatically loads functions/.env at deploy/emulator time.

# Operator contact shown to learners on status screens.
ADMIN_CONTACT=000-0000-0000

# Default administrator account. When this email signs in (email-verified),
# it is auto-granted the admin role and the profile fields below.
ADMIN_APPROVAL_EMAIL=
ADMIN_DEFAULT_NAME=
ADMIN_DEFAULT_PHONE=

# Comma-separated list of emails auto-approved on first bootstrap (QA/test accounts).
PREAPPROVED_TEST_EMAILS=

# Set false in development/QA deployments when Android debug clients do not
# provide App Check tokens. Keep true or omit in production.
ENFORCE_APP_CHECK=true

# Outbound SMTP for pending-approval notifications (optional).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
